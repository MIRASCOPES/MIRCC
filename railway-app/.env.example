# Copy this to .env for local development
# On Railway, set these in the Variables tab

# Your public domain (auto-set by Railway as RAILWAY_PUBLIC_DOMAIN)
# Override manually if using a custom domain
PUBLIC_URL=https://web-production-83ed2.up.railway.app

# Persistent auth key — set this so it doesn't reset on every deploy
# Generate one: node -e "console.log('ENG-' + Math.random().toString(36).slice(2,8).toUpperCase())"
AUTH_KEY=ENG-XXXXXX

# Server port (Railway sets this automatically — do not change)
PORT=3000
